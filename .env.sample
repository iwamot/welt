# Copy this file to .env and fill in your values.

# Bot token (xoxb-...) for Slack Web API calls.
SLACK_BOT_TOKEN=xoxb-...

# App-level token (xapp-1-...) for Socket Mode.
# On Lambda, use SLACK_SIGNING_SECRET instead.
SLACK_APP_TOKEN=xapp-1-...
#SLACK_SIGNING_SECRET=...

# AgentCore Runtime agent ARN, or a managed harness ARN.
AGENT_ARN=arn:aws:bedrock-agentcore:us-west-2:111122223333:runtime/example-agent

# What Welt sends per turn: the full thread history (false, default), or
# only the new messages (true). Runtime agents only; ignored (with a
# startup warning) when AGENT_ARN is a harness ARN.
#AGENT_MANAGES_HISTORY=false

# Comma-separated Converse modalities to accept from Slack uploads
# (image, document, video). Empty (default) disables file input. Runtime
# agents only; ignored (with a startup warning) when AGENT_ARN is a
# harness ARN.
#FILE_INPUT_MODALITIES=

# Logging level for the whole process (default: INFO). DEBUG logs AWS
# credentials — avoid it in production.
#LOG_LEVEL=INFO

# Markdown characters buffered before each streaming update; larger values
# mean fewer Slack API calls (default: 256).
#SLACK_STREAM_BUFFER_SIZE=256
