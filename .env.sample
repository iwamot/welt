# Copy this file to .env and fill in your values.

# Bot token (xoxb-...) for Slack Web API calls.
SLACK_BOT_TOKEN=xoxb-...

# App-level token (xapp-1-...) for Socket Mode (main.py).
# The Lambda entry (lambda_function.py) uses SLACK_SIGNING_SECRET instead.
SLACK_APP_TOKEN=xapp-1-...
#SLACK_SIGNING_SECRET=...

# AgentCore Runtime agent ARN, or a managed harness ARN. A harness needs
# memory enabled (the agentcore CLI default; console-created harnesses may
# have it disabled): Welt sends a harness only the messages it has not seen
# yet, and without memory the harness forgets them once its runtime session
# expires.
AGENT_ARN=arn:aws:bedrock-agentcore:us-west-2:111122223333:runtime/example-agent

# AWS credentials for invoking the agent. Any standard boto3 configuration
# works (IAM role, AWS_PROFILE, access keys). No region setting is needed:
# Welt calls the region named in AGENT_ARN.
#AWS_ACCESS_KEY_ID=...
#AWS_SECRET_ACCESS_KEY=...
#AWS_SESSION_TOKEN=...

# Logging level for the whole process (default: INFO). At DEBUG, botocore
# logs its full wire trace including AWS credential material — treat debug
# logs as sensitive.
#LOG_LEVEL=INFO

# Markdown characters buffered before each streaming update; larger values
# mean fewer Slack API calls (default: 256).
#SLACK_STREAM_BUFFER_SIZE=256

# Comma-separated Converse modalities to accept from Slack uploads
# (image, document, video). Empty disables file input, in which case the
# bot works without the files:read scope. Runtime agents only; ignored
# (with a startup warning) when AGENT_ARN is a harness ARN.
#FILE_INPUT_MODALITIES=

# Set to true when your Runtime agent keeps the conversation history itself
# (e.g. with AgentCore Memory): Welt then sends only the messages the agent
# has not seen yet instead of the full thread (default: false). Runtime
# agents only; a harness always keeps its history, so this is ignored
# (with a startup warning) when AGENT_ARN is a harness ARN.
#AGENT_MANAGES_HISTORY=false

# Message posted to the thread when replying fails. Static text only;
# error details go to the log, never to the channel.
#REPLY_FAILURE_TEXT=:warning: Failed to reply. Please check the app logs.
